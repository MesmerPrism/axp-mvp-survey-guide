%%{init: {"flowchart": {"curve": "natural", "nodeSpacing": 64, "rankSpacing": 104, "padding": 34}}}%%
flowchart TD
  subgraph RuntimeRow[" "]
    direction TB
    subgraph Definition[" "]
      direction TB
      DefinitionTitle["1. Definition<br/>and runtime"]
      DefinitionTitle ~~~ A
      A["Questionnaire definition source<br/>Google Sheet or CSV file<br/>used to define the active survey"] --> B["Loaded questionnaire definition<br/>questionnaire_all_df<br/>long-format R data frame<br/>covering all languages"]
      B --> C["Runtime questionnaire state<br/>questionnaire_df plus metadata<br/>instrument_id, instrument_version,<br/>language, and definition_hash"]
      C --> D["Current participant answers<br/>for the active survey version"]
      D --> E["responses_df in memory<br/>shared answer table<br/>with item_id, type, and value"]
    end
  end

  subgraph ProcessingRow[" "]
    direction LR
    subgraph Derived[" "]
      direction TB
      DerivedTitle["2. In-memory split<br/>and ASC scoring"]
      DerivedTitle ~~~ F
      F["Numeric answer rows<br/>split out from responses_df<br/>item_id, value, and created_at"]
      G["Text and context rows<br/>split out from responses_df<br/>field_id, text or context value,<br/>and created_at"]
      H["ASC factor score rows<br/>computed from numeric answers<br/>must cover 11 canonical scale_id values"]
      I["Current self-score profile<br/>11 canonical ASC factor scores<br/>kept in runtime memory"]

      F --> H --> I
    end

    subgraph Store[" "]
      direction TB
      StoreTitle["3. Durable MariaDB<br/>storage"]
      StoreTitle ~~~ K

      subgraph StoreSources[" "]
        direction TB
        subgraph PeerInputs[" "]
          direction LR
          K["submission<br/>MariaDB table<br/>one durable row<br/>per survey submission"]
          M["response_text<br/>MariaDB table<br/>unique submission_id + field_id"]
          N["score<br/>MariaDB table<br/>unique submission_id + scale_id"]
        end

        subgraph ExportInputs[" "]
          direction LR
          K2["submission<br/>MariaDB table<br/>one durable row<br/>per survey submission"]
          QD["questionnaire_definition<br/>MariaDB table<br/>one snapshot per definition_hash"]
          M2["response_text<br/>MariaDB table<br/>unique submission_id + field_id"]
          N2["score<br/>MariaDB table<br/>unique submission_id + scale_id"]
          L["response_numeric<br/>MariaDB table<br/>unique submission_id + item_id"]
        end
      end

      subgraph StoreBuilds[" "]
        direction LR
        O1["Peer cache build<br/>combine submission context,<br/>q0/q1-derived fields,<br/>and score completeness flags"]
        X1["Quality-gated export row assembly<br/>check one fact per key<br/>and complete 11-factor scores"]
      end

      subgraph StoreOutputs[" "]
        direction LR
        O["peer_plot_submission_cache<br/>MariaDB table<br/>one cached peer-context row<br/>per submission"]
        X["Export-ready normalized rows<br/>submission + numeric + text + score<br/>prepared for export builders"]
      end

      K --> O1
      M --> O1
      N --> O1
      O1 --> O
      C --> QD
      K2 --> X1
      M2 --> X1
      N2 --> X1
      L --> X1
      X1 --> X
    end
  end

  subgraph OutcomeRow[" "]
    direction LR
    subgraph Peer[" "]
      direction TB
      PeerTitle["4. Peer selection,<br/>peer query,<br/>and feedback view"]
      PeerTitle ~~~ P0
      P0["Current submission defaults<br/>selected_drug + selected_dose<br/>mapped to canonical peer tokens"]
      P1["Comparison controls<br/>UI only shows canonical buckets<br/>induction: cannabis / psilocybin / alcohol / mdma<br/>dose: low / medium / high"]
      P2["Selected comparison bucket<br/>example:<br/>psilocybin + medium"]
      P3["Eligible peer context<br/>peer_plot_submission_cache rows<br/>with has_complete_scales = 1"]
      Q["Selected peer score query<br/>join score rows back to eligible peers<br/>then filter to the chosen bucket"]
      R["Rendered peer layers<br/>violin density, quartiles,<br/>and optional peer median path"]
      J["Feedback screen<br/>self-profile overlay,<br/>legend, reading guide,<br/>and share actions"]

      P0 --> P2
      P1 --> P2
      P3 --> Q
      P2 --> Q
      Q --> R --> J
    end

    subgraph Export[" "]
      direction TB
      ExportTitle["5. Distribution<br/>outputs"]
      ExportTitle ~~~ S
      S["Public export builder<br/>creates a wide CSV<br/>and a factor-only CSV"]
      T["Private export builder<br/>creates a wide CSV<br/>with text columns included"]
      U["Public anonymized bundle<br/>session_anon, created_date,<br/>item_* and scale_* columns"]
      V["Private full bundle<br/>submission_id, created_at,<br/>item_*, text_*, and scale_* columns"]

      S --> U
      T --> V
    end
  end

  Definition --> Derived
  Definition --> Store
  Derived --> Store
  Derived --> Peer
  Store --> Peer
  Store --> Export
  Peer ~~~ Export
  Derived ~~~ Store

