flowchart TD
  subgraph Definition["1. Definition and runtime"]
    direction TB
    A["Questionnaire definition source<br/>Google Sheet or CSV file"] --> B["Loaded questionnaire_all_df<br/>R data.frame, long rows, all languages"]
    B --> C["Runtime questionnaire_df plus metadata<br/>R state with instrument_id, instrument_version,<br/>language, definition_hash"]
    C --> D["Participant answers current version"]
    D --> E["responses_df<br/>R data.frame with item_id, type, value"]
  end

  subgraph Derived["2. Split and ASC score rows in memory"]
    direction TB
    E --> F["Numeric answer rows<br/>R data.frame with item_id, value, created_at"]
    E --> G["Text and context rows<br/>R data.frame with field_id, text, created_at"]
    F --> H["ASC factor score rows<br/>R data.frame with canonical scale_id, score_value"]
    H --> I["Current self-score set<br/>11 canonical ASC factors in memory"]
  end

  subgraph Store["3. Durable MariaDB storage"]
    direction LR
    K["submission<br/>MariaDB table<br/>1 row per submission"]
    L["response_numeric<br/>MariaDB table<br/>1 row per numeric item"]
    M["response_text<br/>MariaDB table<br/>1 row per text or context field"]
    N["score<br/>MariaDB table<br/>1 row per ASC factor"]
    O["peer_plot_submission_cache<br/>MariaDB table<br/>1 row per submission context"]
    X["Export-ready normalized rows<br/>submission plus numeric plus text plus score"]

    D --> K
    F --> L
    G --> M
    H --> N
    K --> O
    M --> O
    N --> O
    K --> X
    L --> X
    M --> X
    N --> X
  end

  subgraph Peer["4. Peer comparison query and plotted layers"]
    direction TB
    P["Canonical peer filter buckets<br/>induction: cannabis / psilocybin / alcohol / mdma<br/>dose: low / medium / high"]
    Q["Peer score query result<br/>R data.frame with peer_id, scale_id, value"]
    R["Peer render layers<br/>peer rings or density marks plus median polygon"]
    J["Feedback plot<br/>self polygon plus peer overlay"]

    O --> P --> Q --> R --> J
    I --> J
  end

  subgraph Export["5. Distribution outputs"]
    direction TB
    S["Public export builder<br/>wide CSV plus factor-only CSV"]
    T["Private export builder<br/>wide CSV with text columns"]
    U["Public anonymized bundle<br/>session_anon, created_date,<br/>item_* and scale_* columns"]
    V["Private full bundle<br/>submission_id, created_at,<br/>item_*, text_*, scale_* columns"]

    X --> S --> U
    X --> T --> V
  end

