flowchart TD
  subgraph Definition[""]
    direction TB
    DefinitionTitle["1. Definition and runtime"]
    DefinitionTitle ~~~ A
    A["Questionnaire definition source<br/>Google Sheet or CSV file"] --> B["Loaded questionnaire_all_df<br/>R data.frame, long rows, all languages"]
    B --> C["Runtime questionnaire_df plus metadata<br/>R state with instrument_id, instrument_version,<br/>language, definition_hash"]
    C --> D["Participant answers current version"]
    D --> E["responses_df<br/>R data.frame with item_id, type, value"]
  end

  subgraph Derived[""]
    direction TB
    DerivedTitle["2. In-memory split and ASC scoring"]
    DerivedTitle ~~~ E
    E --> F["Numeric answer rows<br/>R data.frame with item_id, value, created_at"]
    E --> G["Text and context rows<br/>R data.frame with field_id, text, created_at"]
    F --> H["ASC factor score rows<br/>R data.frame with canonical scale_id, score_value"]
    H --> I["Current self-score set<br/>11 canonical ASC factors in memory"]
  end

  subgraph Store[""]
    direction LR
    StoreTitle["3. Durable MariaDB storage"]
    StoreTitle ~~~ K
    K["submission<br/>MariaDB table<br/>1 row per submission"]
    L["response_numeric<br/>MariaDB table<br/>1 row per numeric item"]
    M["response_text<br/>MariaDB table<br/>1 row per text or context field"]
    N["score<br/>MariaDB table<br/>1 row per ASC factor"]
    O["peer_plot_submission_cache<br/>MariaDB table<br/>built from submission + q0/q1 context + score completeness<br/>1 row per submission"]
    X["Export-ready normalized rows<br/>submission plus numeric plus text plus score"]

    D --> K
    F --> L
    G --> M
    H --> N
    K --> O
    M --> O
    N --> O
    K --> X
    L --> X
    M --> X
    N --> X
  end

  subgraph Peer[""]
    direction TB
    PeerTitle["4. Peer selection, query and layers"]
    PeerTitle ~~~ P0
    P0["Current submission defaults<br/>selected_drug + selected_dose<br/>canonicalized to peer tokens"]
    P1["Comparison controls<br/>UI only shows canonical buckets<br/>induction: cannabis / psilocybin / alcohol / mdma<br/>dose: low / medium / high"]
    P2["Selected canonical pair<br/>example: psilocybin + medium"]
    P3["Eligible peer context<br/>peer_plot_submission_cache rows<br/>keep has_complete_scales = 1"]
    Q["Selected peer score query<br/>score JOIN cache by submission_id<br/>filter by selected canonical pair<br/>exclude current submission"]
    R["Peer render layers<br/>peer rings or density marks<br/>plus peer median polygon"]
    J["Feedback plot<br/>self polygon plus peer overlay"]

    G --> P0 --> P2
    P1 --> P2
    O --> P3 --> Q
    P2 --> Q
    N --> Q
    Q --> R --> J
    I --> J
  end

  subgraph Export[""]
    direction TB
    ExportTitle["5. Distribution outputs"]
    ExportTitle ~~~ S
    S["Public export builder<br/>wide CSV plus factor-only CSV"]
    T["Private export builder<br/>wide CSV with text columns"]
    U["Public anonymized bundle<br/>session_anon, created_date,<br/>item_* and scale_* columns"]
    V["Private full bundle<br/>submission_id, created_at,<br/>item_*, text_*, scale_* columns"]

    X --> S --> U
    X --> T --> V
  end

  classDef stageTitle fill:#FFFFFF,stroke:#262632,stroke-width:1.8px,color:#262632,font-size:16px,font-weight:800;
  class DefinitionTitle,DerivedTitle,StoreTitle,PeerTitle,ExportTitle stageTitle;

