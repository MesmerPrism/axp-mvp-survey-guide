flowchart TD
  subgraph Definition["1. Definition and runtime"]
    A["Google Sheets or fallback source"] --> B["Loaded and normalized<br/>questionnaire table"]
    B --> C["Runtime questionnaire state<br/>instrument + version<br/>language + definition hash"]
    C --> D["Participant completes the survey"]
    D --> E["responses_df in memory"]
  end

  subgraph Derived["2. Derived in memory"]
    E --> F["Numeric answers by item_id"]
    E --> G["Text and context answers"]
    F --> H["Scores from scale_id"]
    H --> I["Current self-scores<br/>in memory"]
    I --> J["Immediate feedback"]
  end

  subgraph Store["3. Durable storage"]
    K["submission"]
    L["response_numeric"]
    M["response_text or<br/>context-only rows"]
    N["score"]
    O["peer_plot_submission_cache"]

    D --> K
    F --> L
    G --> M
    H --> N
    K --> O
    M --> O
    N --> O
  end

  subgraph Peer["4. Peer comparison"]
    P["Canonical induction<br/>and dose buckets"]
    Q["Peer comparison inputs"]

    O --> P --> Q --> J
  end

  subgraph Export["5. Distribution outputs"]
    R["Export scripts<br/>widen and split stored rows"]
    S["Public anonymized bundle"]
    T["Private full bundle"]

    K --> R
    L --> R
    M --> R
    N --> R
    R --> S
    R --> T
  end
